<!-- HERO + FORM -->
<section class="bg-soft" style="padding:14px 0 72px" id="form">
  <div class="container">
    <div class="crumb"><a href="index.html">Home</a><span class="sep">/</span><span>Request a Quote</span></div>
    <div class="split" style="align-items:flex-start;gap:56px">
      <!-- LEFT: pitch + contact -->
      <div class="reveal">
        <span class="eyebrow">Let's talk</span>
        <h1>Tell us about your kitchen</h1>
        <p class="lede">Share a few details and we'll come back with a recommendation and a tailored quote. The more we know about your setup, the sharper our advice.</p>

        <ul class="checklist" style="margin:24px 0 32px">
          <li>A real recommendation, not just a price list</li>
          <li>Equipment tuned to your menu &amp; volumes</li>
          <li>One partner for planning, supply &amp; support</li>
        </ul>

        <div class="grid grid-2" style="gap:16px">
          <div class="card"><div class="ic-badge green" style="width:44px;height:44px;font-size:1.2rem"><svg class="ic-svg"><use href="#i-chat"></use></svg></div><h3 style="font-size:1.05rem">WhatsApp</h3><p style="margin:0">Fastest way to reach us<br><a href="#">+65 0000 0000</a></p></div>
          <div class="card"><div class="ic-badge" style="width:44px;height:44px;font-size:1.2rem"><svg class="ic-svg"><use href="#i-mail"></use></svg></div><h3 style="font-size:1.05rem">Email</h3><p style="margin:0"><a href="mailto:enquiry@miifoodservice.com">enquiry@miifoodservice.com</a></p></div>
          <div class="card"><div class="ic-badge" style="width:44px;height:44px;font-size:1.2rem"><svg class="ic-svg"><use href="#i-pin"></use></svg></div><h3 style="font-size:1.05rem">Showroom</h3><p style="margin:0">Singapore<br><span class="muted">Address, to confirm</span></p></div>
          <div class="card"><div class="ic-badge green" style="width:44px;height:44px;font-size:1.2rem">🕑</div><h3 style="font-size:1.05rem">Hours</h3><p style="margin:0">Mon–Fri, 9am–6pm<br><span class="muted">SGT</span></p></div>
        </div>
      </div>

      <!-- RIGHT: form -->
      <div class="reveal">
        <form class="form-card" onsubmit="event.preventDefault();this.style.display='none';document.getElementById('thanks').style.display='block';">
          <h3 style="margin-bottom:6px">Request a Quote</h3>
          <p class="muted" style="font-size:.9rem;margin-bottom:22px">We keep this short on purpose. Fields marked <span style="color:var(--no)">*</span> are required.</p>

          <div class="field-row">
            <div class="field"><label>Name <span class="req">*</span></label><input type="text" required placeholder="Your name"></div>
            <div class="field"><label>Company <span class="req">*</span></label><input type="text" required placeholder="Business name"></div>
          </div>
          <div class="field-row">
            <div class="field"><label>Email <span class="req">*</span></label><input type="email" required placeholder="you@company.com"></div>
            <div class="field"><label>Phone / WhatsApp</label><input type="tel" placeholder="+65 …"></div>
          </div>
          <div class="field-row">
            <div class="field"><label>Your role</label>
              <select><option value="">Select…</option><option>Owner / Founder</option><option>Operations</option><option>Chef / Kitchen</option><option>Procurement</option><option>Other</option></select>
            </div>
            <div class="field"><label>Business type <span class="req">*</span></label>
              <select required><option value="">Select…</option><option>Café / Juice Bar</option><option>Restaurant / Fine Dining</option><option>Hotel</option><option>Chain / QSR</option><option>Institutional / Catering</option><option>Other</option></select>
            </div>
          </div>
          <div class="field-row">
            <div class="field"><label>Products of interest</label>
              <select><option value="">Select a category…</option><option>Beverage &amp; Coffee</option><option>Food Preparation</option><option>Cooking &amp; Ovens</option><option>Oil Management</option><option>Refrigeration &amp; Storage</option><option>Not sure, need advice</option></select>
            </div>
            <div class="field"><label>Quantity / scale</label>
              <select><option value="">Select…</option><option>Single unit</option><option>A few units</option><option>Full kitchen fit-out</option><option>Multi-outlet rollout</option></select>
            </div>
          </div>
          <div class="field"><label>What are you trying to improve?</label><textarea placeholder="e.g. faster service at our juice bar, lower oil cost, a new café fit-out…"></textarea></div>

          <button type="submit" class="btn btn-primary btn-block btn-lg arrow">Send my request</button>
          <p class="muted" style="font-size:.78rem;text-align:center;margin:14px 0 0">By submitting, you agree to be contacted about your enquiry. We don't share your details.</p>
        </form>

        <div id="thanks" class="form-card center" style="display:none">
          <div class="ic-badge green" style="margin:0 auto 16px;width:60px;height:60px;font-size:1.7rem">✓</div>
          <h3>Thanks, we've got it</h3>
          <p class="muted">A member of the Mii team will be in touch within 1–2 working days with a recommendation and quote.</p>
          <a class="btn btn-ghost" href="products.html">Browse products while you wait</a>
        </div>
      </div>
    </div>
  </div>
</section>

